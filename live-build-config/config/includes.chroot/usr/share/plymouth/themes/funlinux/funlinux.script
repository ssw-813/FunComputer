logo = Image("funcomputer-logo.png");
sprite = Sprite(logo);

fun center_logo () {
  sprite.SetX(Window.GetWidth()  / 2 - logo.GetWidth()  / 2);
  sprite.SetY(Window.GetHeight() / 2 - logo.GetHeight() / 2);
}

fun on_refresh_callback () {
  center_logo();
}

Plymouth.SetRefreshFunction(on_refresh_callback);
center_logo();
